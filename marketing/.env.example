# ── Reddit API 凭证 ──────────────────────────────────────────────
# 获取方式：https://www.reddit.com/prefs/apps → Create App → script 类型
REDDIT_CLIENT_ID=你的client_id（14位字母数字）
REDDIT_CLIENT_SECRET=你的client_secret（27位）
REDDIT_USERNAME=你的Reddit用户名
REDDIT_PASSWORD=你的Reddit密码
REDDIT_USER_AGENT=ElementalBond/1.0 by u/你的用户名

# ── Anthropic API（用于生成内容，已有） ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── 视频生成（完全免费，无需填写） ──────────────────────────────
# edge-tts: 不需要API Key，直接使用
# pollinations.ai: 不需要API Key，直接使用
# FFmpeg: 本地安装，不需要API Key
