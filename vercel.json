{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    },
    {
      "src": "api/hello.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    { "source": "/api/hello", "destination": "/api/hello" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/health", "destination": "/api/index" },
    { "source": "/healthz", "destination": "/api/index" },
    { "source": "/readyz", "destination": "/api/index" },
    { "source": "/check_cache", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ],
  "env": {
    "DATABASE_PATH": "/tmp/data.db",
    "REDIS_URL": "",
    "PYTHONPATH": "backend"
  }
}
