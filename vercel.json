{
  "version": 2,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.elemental.bond" }],
      "destination": "https://elemental.bond/$1",
      "permanent": true
    }
  ],
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/frontend/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/frontend/robots.txt"
    },
    {
      "src": "/og-image.png",
      "dest": "/frontend/og-image.png"
    },
    {
      "src": "/sw.js",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/frontend/sw.js"
    },
    {
      "src": "/manifest.json",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/frontend/manifest.json"
    },
    {
      "src": "/icons/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/frontend/icons/$1"
    },
    {
      "src": "/offline.html",
      "headers": { "cache-control": "public, max-age=0, must-revalidate" },
      "dest": "/frontend/offline.html"
    },
    {
      "src": "/covers/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/covers/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ],
  "env": {
    "DATABASE_PATH": "/tmp/data.db",
    "REDIS_URL": "",
    "PYTHONPATH": "backend",
    "FLASK_ENV": "production"
  }
}
